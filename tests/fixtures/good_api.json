{
  "openapi": "3.0.3",
  "info": {
    "title": "User Management API",
    "version": "1.0.0",
    "description": "API for managing user accounts and profiles"
  },
  "security": [
    {"bearerAuth": []}
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "email": {"type": "string", "format": "email"}
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {"type": "integer"},
          "message": {"type": "string"}
        }
      }
    }
  },
  "paths": {
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "Retrieve a paginated list of all registered users in the system",
        "description": "Use this endpoint to retrieve users. Returns a paginated list that allows filtering by status and role.",
        "tags": ["users"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination, starting from 1",
            "required": false,
            "schema": {"type": "integer", "default": 1}
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of items per page, maximum 100",
            "required": false,
            "schema": {"type": "integer", "default": 20}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with user list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/User"}
                    },
                    "total": {"type": "integer"}
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters provided"
          }
        }
      },
      "post": {
        "operationId": "createUser",
        "summary": "Create a new user account with the provided profile information",
        "description": "Use this endpoint to register a new user. Requires name and email fields. Returns the created user object with generated ID.",
        "tags": ["users"],
        "requestBody": {
          "description": "User creation payload with required profile fields",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Full name of the user"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email address for the user account"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/User"}
              }
            }
          },
          "400": {
            "description": "Invalid request body or missing required fields"
          }
        }
      }
    },
    "/users/{userId}": {
      "get": {
        "operationId": "getUserById",
        "summary": "Retrieve detailed information for a specific user by their ID",
        "description": "Use this endpoint to get a single user profile. The userId is returned from the listUsers endpoint.",
        "tags": ["users"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "description": "Unique user identifier, obtained from the listUsers response",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "User found and returned successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/User"}
              }
            }
          },
          "404": {
            "description": "User not found with the given ID"
          }
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Permanently delete a user account and all associated data",
        "description": "Use this endpoint to remove a user. This action is irreversible and deletes all user data.",
        "tags": ["users"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "description": "Unique user identifier, obtained from the listUsers response",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "204": {
            "description": "User deleted successfully"
          },
          "404": {
            "description": "User not found with the given ID"
          }
        }
      }
    }
  }
}
